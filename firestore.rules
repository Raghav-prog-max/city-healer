rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // DEFAULT: deny everything unless a rule below explicitly allows
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // FIX 1: Role helpers — read the user's role from their Firestore
    // profile instead of trusting the token claim (safer)
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'ADMIN';
    }

    function isDoctor() {
      return isSignedIn() && getUserRole() == 'DOCTOR';
    }

    function isHospital() {
      return isSignedIn() && getUserRole() == 'HOSPITAL';
    }

    function isPatient() {
      return isSignedIn() && getUserRole() == 'PATIENT';
    }

    // ─────────────────────────────────────────────────────────────
    // VALIDATION HELPERS (unchanged from your original — good work)
    // ─────────────────────────────────────────────────────────────

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 150
        && data.email is string && data.email.size() <= 150
        && (data.phone == null || (data.phone is string && data.phone.size() <= 50))
        && data.role is string
        && (data.role == 'PATIENT' || data.role == 'DOCTOR' || data.role == 'HOSPITAL' || data.role == 'ADMIN')
        && (data.age == null || data.age is number)
        && (data.gender == null || (data.gender is string && data.gender.size() <= 50))
        && (data.bloodGroup == null || (data.bloodGroup is string && data.bloodGroup.size() <= 10))
        && (data.policyNo == null || (data.policyNo is string && data.policyNo.size() <= 100));
    }

    function isValidHospital(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.address is string && data.address.size() <= 400
        && data.totalBeds is number && data.availableBeds is number
        && data.icuBeds is number && data.icuAvailable is number
        && data.emergencyOccupancy is number
        && data.lat is number && data.lng is number
        && data.phone is string && data.phone.size() <= 50
        && data.rating is number
        && data.email is string && data.email.size() <= 150
        && data.specialties is list
        && data.categories is list;
    }

    function isValidDoctor(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        && data.specialty is string && data.specialty.size() <= 150
        && data.rating is number
        && data.experience is number
        && data.patientsServed is number
        && data.online is bool
        && data.queueCount is number
        && data.hospitalName is string && data.hospitalName.size() <= 200
        && data.waitTimeMin is number;
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128
        && data.patientId is string && data.patientId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 150
        && data.doctorId is string && data.doctorId.size() <= 128
        && data.doctorName is string && data.doctorName.size() <= 150
        && data.specialty is string && data.specialty.size() <= 150
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 20
        && data.status is string
        && (data.status == 'PENDING' || data.status == 'ACCEPTED' || data.status == 'DECLINED' || data.status == 'COMPLETED')
        && data.type is string
        && (data.type == 'VIRTUAL' || data.type == 'IN_PERSON');
    }

    function isValidQueueToken(data) {
      return data.id is string && data.id.size() <= 128
        && data.tokenNumber is string && data.tokenNumber.size() <= 50
        && data.patientId is string && data.patientId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 150
        && data.doctorId is string && data.doctorId.size() <= 128
        && data.doctorName is string && data.doctorName.size() <= 150
        && data.estimatedWaitTimeMin is number
        && data.status is string
        && (data.status == 'WAITING' || data.status == 'SERVING' || data.status == 'COMPLETED' || data.status == 'SKIPPED')
        && data.checkpointTime is string && data.checkpointTime.size() <= 20;
    }

    function isValidMedicalRecord(data) {
      return data.id is string && data.id.size() <= 128
        && data.patientId is string && data.patientId.size() <= 128
        && data.date is string && data.date.size() <= 20
        && data.title is string && data.title.size() <= 200
        && data.doctorName is string && data.doctorName.size() <= 150
        && data.diagnoseSummary is string && data.diagnoseSummary.size() <= 2000;
    }

    function isValidPrescription(data) {
      return data.id is string && data.id.size() <= 128
        && data.appointmentId is string && data.appointmentId.size() <= 128
        && data.patientId is string && data.patientId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 150
        && data.doctorId is string && data.doctorId.size() <= 128
        && data.doctorName is string && data.doctorName.size() <= 150
        && data.date is string && data.date.size() <= 20
        && data.diagnosis is string && data.diagnosis.size() <= 1000
        && data.medicines is list;
    }

    function isValidMedicineOrder(data) {
      return data.id is string && data.id.size() <= 128
        && data.patientId is string && data.patientId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 150
        && data.totalAmount is number
        && data.status is string
        && data.prescriptionAttached is bool
        && data.deliveryAddress is string && data.deliveryAddress.size() <= 400;
    }

    function isValidEmergencyAlert(data) {
      return data.id is string && data.id.size() <= 128
        && data.patientId is string && data.patientId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 150
        && data.patientPhone is string && data.patientPhone.size() <= 50
        && data.lat is number && data.lng is number
        && data.address is string && data.address.size() <= 400
        && data.type is string && data.type.size() <= 100
        && data.status is string
        && (data.status == 'REPORTED' || data.status == 'DISPATCHED' || data.status == 'RESOLVED')
        && data.assignedAmbulanceRef is string && data.assignedAmbulanceRef.size() <= 50
        && data.hospitalName is string && data.hospitalName.size() <= 200;
    }

    // ─────────────────────────────────────────────────────────────
    // USERS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // A user can only read their own profile
      allow get: if isOwner(userId) && isValidId(userId);

      // FIX 2: Patients can only self-register as PATIENT
      // Doctors and hospitals must be created by ADMIN via server-side SDK
      allow create: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == userId
        && incoming().role == 'PATIENT'       // <-- NEW: prevent self-assigning DOCTOR/ADMIN role
        && incoming().createdAt == request.time;

      // A user can update their own profile but NOT change their role or uid
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().uid == existing().uid
        && incoming().role == existing().role  // role is immutable after creation
        && incoming().email == existing().email; // email changes go through Firebase Auth only

      // FIX 3: Admins can read any user profile (needed for admin panel)
      allow get: if isAdmin();

      // Nobody can delete user profiles (audit trail)
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // HOSPITALS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /hospitals/{hospitalId} {
      // Any signed-in user can view hospital info (beds, location, etc.)
      allow read: if isSignedIn();

      // FIX 4: Hospital accounts can update their OWN bed/capacity data
      // but cannot change immutable fields like id, name, address
      allow update: if isHospital()
        && isValidId(hospitalId)
        && isValidHospital(incoming())
        && incoming().id == existing().id         // id is immutable
        && incoming().name == existing().name     // name is immutable
        && incoming().address == existing().address; // address is immutable

      // Only admins can create or fully manage hospitals
      allow create, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // DOCTORS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /doctors/{doctorId} {
      // Any signed-in user can view doctor profiles
      allow read: if isSignedIn();

      // FIX 5: Doctors can update their own availability (online status,
      // queue count, wait time) but not their credentials or rating
      allow update: if isDoctor()
        && request.auth.uid == doctorId
        && isValidDoctor(incoming())
        && incoming().id == existing().id
        && incoming().name == existing().name
        && incoming().specialty == existing().specialty
        && incoming().experience == existing().experience
        && incoming().hospitalName == existing().hospitalName;
        // Doctors can only change: online, queueCount, waitTimeMin, patientsServed

      // Only admins can create or delete doctor profiles
      allow create, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // APPOINTMENTS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /appointments/{appointmentId} {
      // Patient sees their own appointments; doctor sees appointments assigned to them
      allow read: if isSignedIn()
        && (resource.data.patientId == request.auth.uid
            || resource.data.doctorId == request.auth.uid);

      // Only patients can book appointments, and only for themselves
      allow create: if isSignedIn()
        && isValidId(appointmentId)
        && isValidAppointment(incoming())
        && incoming().patientId == request.auth.uid
        && incoming().status == 'PENDING';  // FIX 6: must start as PENDING

      // FIX 7: Patients can cancel (PENDING only); doctors can accept/decline/complete
      allow update: if isSignedIn()
        && isValidId(appointmentId)
        && isValidAppointment(incoming())
        && incoming().patientId == existing().patientId   // patient cannot be swapped
        && incoming().doctorId == existing().doctorId     // doctor cannot be swapped
        && (
          // Patient can only cancel their own pending appointment
          (request.auth.uid == existing().patientId
            && existing().status == 'PENDING'
            && incoming().status == 'DECLINED')
          ||
          // Doctor can accept, decline, or complete
          (request.auth.uid == existing().doctorId
            && (incoming().status == 'ACCEPTED'
                || incoming().status == 'DECLINED'
                || incoming().status == 'COMPLETED'))
        );

      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // QUEUE TOKENS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /queue/{tokenId} {
      // FIX 8: Was "any signed-in user can read all tokens" — now scoped
      // to only the patient or doctor on that token
      allow read: if isSignedIn()
        && (resource.data.patientId == request.auth.uid
            || resource.data.doctorId == request.auth.uid);

      // Only patients can create tokens for themselves
      allow create: if isSignedIn()
        && isValidId(tokenId)
        && isValidQueueToken(incoming())
        && incoming().patientId == request.auth.uid
        && incoming().status == 'WAITING';  // must start as WAITING

      // Patients or doctors on this token can update it
      allow update: if isSignedIn()
        && isValidId(tokenId)
        && isValidQueueToken(incoming())
        && (existing().patientId == request.auth.uid
            || existing().doctorId == request.auth.uid)
        && incoming().patientId == existing().patientId
        && incoming().doctorId == existing().doctorId;

      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // MEDICAL RECORDS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /records/{recordId} {
      // Only the patient themselves can read their own records
      allow read: if isSignedIn()
        && resource.data.patientId == request.auth.uid;

      // Patients can create their own records
      allow create: if isSignedIn()
        && isValidId(recordId)
        && isValidMedicalRecord(incoming())
        && incoming().patientId == request.auth.uid;

      // Patients can update their own records but cannot change patientId
      allow update: if isSignedIn()
        && isValidId(recordId)
        && isValidMedicalRecord(incoming())
        && existing().patientId == request.auth.uid
        && incoming().patientId == existing().patientId;  // patientId is immutable

      // FIX 9: Medical records should NOT be deletable by patients
      // (important for audit trail in healthcare). Use archive flag instead.
      // If you need soft-delete, add an "archived: true" field via update above.
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // PRESCRIPTIONS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /prescriptions/{prescriptionId} {
      // Patient sees their own; doctor sees ones they wrote
      allow read: if isSignedIn()
        && (resource.data.patientId == request.auth.uid
            || resource.data.doctorId == request.auth.uid);

      // FIX 10: Only doctors can write prescriptions (not patients)
      allow create: if isDoctor()
        && isValidPrescription(incoming())
        && incoming().doctorId == request.auth.uid;

      // Prescriptions are immutable once written (medical-legal requirement)
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // MEDICINES COLLECTION (catalogue)
    // ─────────────────────────────────────────────────────────────
    match /medicines/{medicineId} {
      // Any signed-in user can browse medicines
      allow read: if isSignedIn();

      // Only admins can manage the medicine catalogue
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // MEDICINE ORDERS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /medicineOrders/{orderId} {
      // Only the patient who placed the order can view it
      allow read: if isSignedIn()
        && resource.data.patientId == request.auth.uid;

      // Patients can only place orders for themselves
      allow create: if isSignedIn()
        && isValidId(orderId)
        && isValidMedicineOrder(incoming())
        && incoming().patientId == request.auth.uid;

      // FIX 11: Patients can only cancel PENDING orders, not change delivery address
      // after dispatch or modify amount. Admins handle status changes.
      allow update: if isSignedIn()
        && isValidMedicineOrder(incoming())
        && existing().patientId == request.auth.uid
        && incoming().patientId == existing().patientId
        && incoming().totalAmount == existing().totalAmount   // amount is immutable
        && incoming().deliveryAddress == existing().deliveryAddress; // address is immutable after order

      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // EMERGENCY ALERTS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /emergencyAlerts/{alertId} {
      // Patient can see their own alerts; admins can see all
      allow read: if isSignedIn()
        && (resource.data.patientId == request.auth.uid || isAdmin());

      // Only patients can trigger SOS alerts for themselves
      allow create: if isSignedIn()
        && isValidId(alertId)
        && isValidEmergencyAlert(incoming())
        && incoming().patientId == request.auth.uid
        && incoming().status == 'REPORTED';   // must start as REPORTED

      // FIX 12: Patients CANNOT update their emergency alert status
      // (previously they could set their own status to RESOLVED)
      // Only admins/dispatch can update status to DISPATCHED or RESOLVED
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ACTIVE CHATS COLLECTION
    // ─────────────────────────────────────────────────────────────
    match /activeChats/{appointmentId} {
      // FIX 13: This was completely open to any signed-in user
      // Now only the patient or doctor on this specific appointment can access it
      allow read, write: if isSignedIn()
        && (
          // Check the appointment document to verify they are a participant
          get(/databases/$(database)/documents/appointments/$(appointmentId)).data.patientId == request.auth.uid
          ||
          get(/databases/$(database)/documents/appointments/$(appointmentId)).data.doctorId == request.auth.uid
        );
    }

    // ─────────────────────────────────────────────────────────────
    // TEST / HEALTH CHECK COLLECTION
    // FIX 14: Was publicly readable (no auth required) — now requires sign-in
    // to prevent leaking any data accidentally stored here
    // ─────────────────────────────────────────────────────────────
    match /test/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // ADMIN COLLECTION (new — for admin-only platform settings)
    // ─────────────────────────────────────────────────────────────
    match /adminConfig/{docId} {
      allow read, write: if isAdmin();
    }

  }
}
